# TrackHS MCP Connector - Variables de Entorno
# Copia este archivo como .env y configura tus valores

# =============================================================================
# CONFIGURACIÓN TRACKHS API (REQUERIDAS)
# =============================================================================

# URL base de la API de TrackHS
# ⚠️ IMPORTANTE: NO incluir /api al final
# ✅ CORRECTO: https://ihmvacations.trackhs.com
# ❌ INCORRECTO: https://ihmvacations.trackhs.com/api (causa error 404 - doble /api)
# Los endpoints ya incluyen /api, el código lo agrega automáticamente
# Ver docs/URL_CONFIGURATION.md para más detalles
TRACKHS_API_URL=https://ihmvacations.trackhs.com

# Credenciales de TrackHS
TRACKHS_USERNAME=tu_usuario_trackhs
TRACKHS_PASSWORD=tu_contraseña_trackhs

# Timeouts para requests a TrackHS (en segundos)
# - TRACKHS_TIMEOUT: Timeout general para peticiones (default: 60s)
# - TRACKHS_SEARCH_TIMEOUT: Timeout extendido para búsquedas complejas (default: 120s)
TRACKHS_TIMEOUT=60
TRACKHS_SEARCH_TIMEOUT=120

# =============================================================================
# CONFIGURACIÓN SERVIDOR HTTP (MANEJADA POR FASTMCP CLOUD)
# =============================================================================

# FastMCP Cloud maneja automáticamente:
# - HOST, PORT: Configurados en fastmcp.yaml
# - CORS: Configurado en fastmcp.yaml
# - Transporte HTTP: Automático en FastMCP Cloud

# Variables opcionales para desarrollo local:
# HOST=0.0.0.0
# PORT=8080
# CORS_ORIGINS=https://elevenlabs.io,https://app.elevenlabs.io

# =============================================================================
# CONFIGURACIÓN DESARROLLO (OPCIONALES)
# =============================================================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modo debug (true/false)
DEBUG=false

# =============================================================================
# CONFIGURACIÓN FASTMCP (NUEVAS VARIABLES)
# =============================================================================

# Nivel de logging específico para FastMCP (DEBUG, INFO, WARNING, ERROR)
FASTMCP_LOG_LEVEL=INFO

# Si incluir traceback en logs de error (true/false)
FASTMCP_INCLUDE_TRACEBACK=false

# Si enmascarar detalles de error para clientes (true/false)
FASTMCP_MASK_ERROR_DETAILS=false

# Si usar validación estricta de parámetros (true/false)
FASTMCP_STRICT_INPUT_VALIDATION=true

# =============================================================================
# OPTIMIZACIÓN DE RESPUESTAS PARA AGENTES DE VOZ (OPCIONALES)
# =============================================================================

# ⚠️ IMPORTANTE: Para agentes de voz como ElevenLabs + Gemini 2.5
# Las respuestas largas pueden causar errores y consumir demasiado contexto

# Si compactar automáticamente las respuestas (true/false)
# Elimina campos innecesarios y mantiene solo información esencial
TRACKHS_COMPACT_RESPONSES=true

# Máximo número de items a retornar en búsquedas
# Recomendado: 3-5 para agentes de voz, 10-25 para análisis
TRACKHS_MAX_RESPONSE_ITEMS=3

# Máximo número estimado de tokens por respuesta
# Recomendado: 2000 para agentes de voz, 5000 para análisis
TRACKHS_MAX_RESPONSE_TOKENS=2000